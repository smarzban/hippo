# ──────────────────────────────────────────────────────────────────────────────
# Hippo configuration.  Copy to .env and edit:   cp .env.example .env
#
# Two kinds of variables live here:
#   • HIPPO_*  — read by Hippo (pydantic-settings, HIPPO_ prefix). Defaults are
#                shown commented out; uncomment a line to override the default.
#   • OPENAI_* — read from the PROCESS ENVIRONMENT, not by Hippo. They are NOT
#                auto-loaded from this file, so start Hippo with the env loaded:
#                    set -a; source .env; set +a
#                    uv run hippo serve
# ──────────────────────────────────────────────────────────────────────────────

# ── Model provider ────────────────────────────────────────────────────────────
# Default: OpenAI. Set a real key; leave OPENAI_BASE_URL unset.
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# Alternative: local Ollama (optionally backed by Ollama Cloud) via its
# OpenAI-compatible API. Ollama Cloud does NOT serve an embeddings endpoint, so the
# embedding model must be a LOCAL one (see HIPPO_EMBEDDING_MODEL/DIM below). To use
# this path, comment the two lines above and uncomment these:
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Core ───────────────────────────────────────────────────────────────────────
# HIPPO_DB_PATH=hippo.db                          # the whole brain is this one file
# HIPPO_CHAT_MODEL=openai:gpt-5.2                 # any pydantic-ai model string
# HIPPO_EMBEDDING_MODEL=text-embedding-3-small    # 'fake' = offline deterministic (dev/tests)
# HIPPO_EMBEDDING_DIM=1536                         # must match the model; run `hippo reindex` after changing
# HIPPO_ENRICH_ENABLED=true                        # contextual lines + summaries at ingest
# HIPPO_ENRICH_MODEL=openai:gpt-5-mini
# HIPPO_CHUNK_MAX_CHARS=3000                       # ~750 tokens per chunk
# HIPPO_CHUNK_OVERLAP_CHARS=200
# HIPPO_MAX_TOOL_CALLS=15                           # agent tool-call budget per question
# HIPPO_SEARCH_TOP_K=8                              # chunks retrieved per search

# Ollama-local model values (uncomment alongside the Ollama provider block above):
# HIPPO_CHAT_MODEL=openai:gpt-oss:120b-cloud       # 20b-cloud returns empty content via /v1 — use 120b
# HIPPO_ENRICH_MODEL=openai:gpt-oss:120b-cloud
# HIPPO_EMBEDDING_MODEL=nomic-embed-text
# HIPPO_EMBEDDING_DIM=768

# ── Ingestion limits ────────────────────────────────────────────────────────────
# HIPPO_MAX_UPLOAD_BYTES=10485760                  # reject larger uploads (413)
# HIPPO_MAX_DOC_CHARS=1000000                      # skip docs over this many chars (status: skipped)
# HIPPO_MAX_DECOMPRESSED_BYTES=100000000           # .docx ZIP-bomb guard (uncompressed)

# ── Auth (see README → Authentication) ───────────────────────────────────────────
# HIPPO_AUTH_MODE=none                             # none | oidc | iap | password
# HIPPO_ALLOWED_DOMAIN=                            # e.g. example.com; empty = any domain
# HIPPO_ADMIN_EMAILS=                              # comma-separated bootstrap admins (always admin)
# HIPPO_SECRET_KEY=                                # session-cookie signing; required in oidc and password
# HIPPO_OIDC_CLIENT_ID=
# HIPPO_OIDC_CLIENT_SECRET=
# HIPPO_PUBLIC_URL=http://localhost:8000           # OIDC redirect URI base
# HIPPO_IAP_AUDIENCE=                              # required in iap mode

# ── Sources / upload-to-repo ─────────────────────────────────────────────────────
# HIPPO_SOURCE_ROOTS=                              # colon-separated allowed ingest dirs; required in oidc/iap
# HIPPO_GITHUB_TOKEN=                              # PAT for upload-to-repo
# HIPPO_GITHUB_DOCS_REPO=                          # owner/repo for team (developer) docs
# HIPPO_GITHUB_MANAGERS_REPO=                      # owner/repo for manager docs
# HIPPO_GITHUB_BRANCH=main

# ── Serving / integrations ───────────────────────────────────────────────────────
# HIPPO_UI_DIST=                                   # path to built UI (ui/dist) to serve on one origin (:8000)
# HIPPO_MCP_ENABLED=true                           # mount the /mcp MCP server
# HIPPO_SLACK_ENABLED=false                        # `hippo slack` refuses to start unless true
# HIPPO_SLACK_BOT_TOKEN=                           # xoxb-… bot token
# HIPPO_SLACK_APP_TOKEN=                           # xapp-… app-level token (Socket Mode)
# HIPPO_SETUP_TOKEN=                               # first-run wizard gate; if unset a random token is logged at startup
